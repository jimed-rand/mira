GRUB_DEFAULT=0
GRUB_TIMEOUT=5
GRUB_DISTRIBUTOR="Mira"
# Parameters below are migrated from the former extlinux.conf
GRUB_CMDLINE_LINUX_DEFAULT="rootflags=data=writeback rw console=ttyAML0,115200n8 console=tty0 no_console_suspend consoleblank=0 fsck.fix=yes fsck.repair=yes net.ifnames=0 loglevel=4 audit=0 nowatchdog"
GRUB_CMDLINE_LINUX=""

# Uncomment if you want to use a specific Device Tree (DTB)
GRUB_FDT="/dtbs/amlogic/meson-gxl-s905x-p212.dtb"

# EFI/GPT specific tuning
GRUB_DISABLE_RECOVERY=true
#GRUB_DISABLE_LINUX_UUID=true
